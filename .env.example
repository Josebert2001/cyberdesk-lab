# Frontend environment variables
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
VITE_GEMINI_API_KEY=your_optional_browser_fallback_gemini_api_key

# Keep GEMINI_API_KEY in your Supabase Edge Function secrets.
# VITE_GEMINI_API_KEY is only for local or fallback use when the Edge Function is unavailable.
